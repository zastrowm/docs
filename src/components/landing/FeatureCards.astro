---
/**
 * 8 feature cards in 2-column grid with mini code snippets.
 */
import CodeBlock from './CodeBlock.astro'
import { features } from '../../data/feature-cards'
---

<section class="features-section">
  <div class="features-inner">
    <h2 class="section-heading">Everything you need to build agents</h2>
    <div class="features-grid">
      {features.map((feature) => (
        <div class="feature-card">
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
          <div class="feature-code">
            <CodeBlock code={feature.code} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 3rem 2rem 5rem;
    display: flex;
    justify-content: center;
  }

  .features-inner {
    max-width: 1200px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .section-heading {
    font-family: 'Figtree', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 600;
    color: var(--sl-color-white);
    text-align: center;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .section-description {
    font-family: 'Figtree', sans-serif;
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--sl-color-gray-3);
    text-align: center;
    margin: 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    row-gap: 1.5rem;
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    min-width: 0;
  }

  :global([data-theme='light']) .feature-card {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.08);
  }

  .feature-card:hover {
    border-color: rgba(0, 204, 95, 0.3);
    box-shadow: 0 0 24px rgba(0, 204, 95, 0.06);
  }

  .feature-title {
    font-family: 'Figtree', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0;
  }

  .feature-description {
    font-family: 'Figtree', sans-serif;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--sl-color-gray-3);
    margin: 0;
  }

  .feature-code :global(.code-block) {
    font-size: 0.78rem;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .features-section {
      padding: 2rem 1.5rem 3rem;
    }
    .features-grid {
      grid-template-columns: 1fr;
    }
    .feature-code :global(.code-block) {
      font-size: 0.72rem;
    }
  }

  @media (max-width: 430px) {
    .features-section {
      padding: 2rem 1rem 3rem;
    }
    .feature-card {
      padding: 1rem;
      border-radius: 10px;
    }
  }
</style>
