<script>
  import { resolveRedirectFromUrl } from '../util/redirect'

  const target = resolveRedirectFromUrl(window.location.href)
  if (target) {
    const base = import.meta.env.BASE_URL.replace(/\/$/, '')
    const dest = target === '/' ? `${base}/` : `${base}/${target}`
    const currentPath = window.location.pathname.replace(/\/+$/, '')
    const destPath = dest.replace(/\/+$/, '')
    if (destPath !== currentPath) {
      window.location.replace(dest)
    }
  }
</script>
